{
  "name": "groceries-client",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "autoprefixer": "10.4.27",
    "axios": "^1.13.5",
    "env-cmd": "11.0.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-destructuring": "^2.2.1",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-plugin-react": "7.37.5",
    "immutability-helper": "3.1.1",
    "luxon": "^3.7.2",
    "postcss": "8.5.8",
    "prettier": "3.8.1",
    "query-string": "9.3.1",
    "react": "19.2.4",
    "react-async": "10.0.1",
    "react-dom": "19.2.4",
    "react-idle-timer": "5.7.2",
    "react-router": "^7.12.0",
    "react-toastify": "11.0.5",
    "typescript-eslint": "^8.0.0"
  },
  "scripts": {
    "start": "VITE_VERSION=$(git rev-parse --short HEAD) vite",
    "build": "tsc --noEmit && vite build",
    "build:production": "rm -rf build && VITE_VERSION=$(git rev-parse --short HEAD) npm run build",
    "deploy:production": "sh scripts/deploy-prod.sh",
    "build:staging": "rm -rf build && VITE_VERSION=$(git rev-parse --short HEAD) env-cmd -f .env.staging vite build",
    "deploy:staging": "sh scripts/deploy-staging.sh",
    "preview": "vite preview",
    "lint": "eslint --ext .ts,.tsx src/",
    "test": "vitest",
    "test:watch": "vitest",
    "test:ci": "tsc --noEmit && npm run lint && vitest run --coverage",
    "format": "prettier --write 'src/**/*.{ts,tsx,json,css,md}'",
    "analyze": "npm run build:production && source-map-explorer 'build/assets/*.js'",
    "build:lighthouse": "rm -rf build && VITE_API_BASE=http://localhost:3300 VITE_VERSION=$(git rev-parse --short HEAD) vite build",
    "lighthouse": "lhci autorun",
    "lighthouse:mobile": "lhci autorun --config=lighthouserc.mobile.js"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "eslint:recommended",
      "plugin:@typescript-eslint/strict",
      "plugin:react/recommended",
      "plugin:destructuring/recommended",
      "prettier"
    ],
    "parser": "@typescript-eslint/parser",
    "plugins": [
      "@typescript-eslint",
      "destructuring"
    ],
    "parserOptions": {
      "project": [
        "./tsconfig.json"
      ]
    },
    "rules": {
      "no-console": "error",
      "max-len": [
        "error",
        {
          "code": 120,
          "tabWidth": 2
        }
      ],
      "curly": [
        "error",
        "all"
      ],
      "no-unused-vars": "off",
      "destructuring/in-params": [
        "error",
        {
          "max-params": 0
        }
      ],
      "destructuring/no-rename": "off",
      "@typescript-eslint/no-unused-vars": "error",
      "@typescript-eslint/consistent-type-definitions": [
        "error",
        "interface"
      ],
      "@typescript-eslint/no-explicit-any": "error",
      "@typescript-eslint/no-inferrable-types": "error",
      "@typescript-eslint/explicit-function-return-type": "error",
      "@typescript-eslint/naming-convention": [
        "error",
        {
          "selector": "variableLike",
          "format": [
            "camelCase",
            "UPPER_CASE",
            "PascalCase"
          ]
        }
      ],
      "@typescript-eslint/member-delimiter-style": [
        "error",
        {
          "multiline": {
            "delimiter": "semi",
            "requireLast": true
          },
          "singleline": {
            "delimiter": "semi",
            "requireLast": false
          }
        }
      ],
      "@typescript-eslint/consistent-type-imports": "error",
      "@typescript-eslint/prefer-optional-chain": "error",
      "@typescript-eslint/semi": [
        "error",
        "always"
      ],
      "@typescript-eslint/type-annotation-spacing": "error",
      "@typescript-eslint/no-empty-function": "error",
      "@typescript-eslint/explicit-module-boundary-types": "error"
    }
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@lhci/cli": "^0.15.1",
    "@tailwindcss/vite": "^4.2.1",
    "@types/luxon": "^3.7.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.0",
    "jsdom": "^28.1.0",
    "source-map-explorer": "^2.5.3",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vite": "^8.0.0",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.0",
    "web-vitals": "^5.1.0",
    "webpack-bundle-analyzer": "^5.0.0"
  }
}
