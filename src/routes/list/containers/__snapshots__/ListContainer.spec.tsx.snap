exports[`ListContainer > Item Rendering > does not render incomplete items when none exist 1`] = `
<div>
  <a
    class="float-end"
    data-discover="true"
    href="/lists"
  >
    Back to lists
  </a>
  <h1>
    foo
  </h1>
  <br />
  <button
    aria-controls="form-collapse"
    aria-expanded="false"
    class="btn btn-link"
    data-test-id="add-item-button"
    type="button"
  >
    Add Item
  </button>
  <form
    autocomplete="off"
    class="collapse"
    data-test-id="list-item-form"
    id="form-collapse"
  >
    <div
      aria-busy="true"
      aria-live="polite"
      role="status"
    >
      <div
        class="placeholder-glow"
      >
        <span
          class="placeholder col-6"
        />
        <span
          class="placeholder col-4"
        />
        <span
          class="placeholder col-8"
        />
      </div>
    </div>
    <div
      class="tw:mb-3"
    >
      <div
        class="tw:w-full"
      >
        <label
          class="tw:block tw:text-sm tw:font-medium tw:text-[var(--color-text-secondary)] tw:mb-2"
          for="category"
        >
          Category
        </label>
        <input
          class="tw:w-full tw:h-11 tw:px-4 tw:py-2 tw:bg-[var(--color-surface)] tw:border tw:border-[var(--color-border)] tw:rounded-lg tw:text-base tw:transition-colors tw:focus:outline-none tw:focus:ring-2 tw:focus:ring-[var(--color-primary)]/30 tw:focus:border-[var(--color-border-strong)]"
          id="category"
          list="categories"
          name="category"
          type="text"
          value=""
        />
      </div>
      <datalist
        data-test-id="categories"
        id="categories"
      >
        <option
          value="foo"
        />
        <option
          value="bar"
        />
      </datalist>
    </div>
    <div
      class="mb-3 tw:mb-3"
    >
      <label
        class="tw:flex tw:items-center tw:min-h-[44px] tw:cursor-pointer tw:gap-3"
      >
        <div
          class="tw:relative tw:w-5 tw:h-5"
        >
          <input
            class="tw:appearance-none tw:absolute tw:w-5 tw:h-5 tw:rounded tw:border-2 tw:border-[var(--color-border)] tw:bg-[var(--color-surface)] tw:cursor-pointer tw:transition-colors tw:focus:outline-none tw:focus:ring-2 tw:focus:ring-[var(--color-primary)]/30"
            id="completed"
            name="completed"
            type="checkbox"
          />
          <div
            class="tw:absolute tw:inset-0 tw:w-5 tw:h-5 tw:rounded tw:border-2 tw:border-[var(--color-border)] tw:bg-[var(--color-surface)] tw:pointer-events-none"
          />
        </div>
        <span
          class="tw:text-sm tw:select-none tw:text-[var(--color-text-primary)]"
        >
          Completed
        </span>
      </label>
    </div>
    <div
      class="d-grid gap-2 mt-3"
    >
      <button
        class="tw:font-medium tw:transition-colors tw:duration-200 tw:ease-in-out tw:min-h-[44px] tw:flex tw:items-center tw:justify-center tw:gap-2 tw:bg-[var(--color-success)] tw:text-white tw:hover:opacity-90 tw:active:opacity-80 tw:h-10 tw:px-4 tw:text-sm tw:rounded-lg tw:w-full tw:cursor-pointer"
        type="submit"
      >
        Add New Item
      </button>
      <button
        class="tw:font-medium tw:transition-colors tw:duration-200 tw:ease-in-out tw:min-h-[44px] tw:flex tw:items-center tw:justify-center tw:gap-2 tw:text-[var(--color-text-secondary)] tw:hover:bg-[var(--color-surface-overlay)] tw:active:bg-[var(--color-surface-raised)] tw:h-10 tw:px-4 tw:text-sm tw:rounded-lg tw:w-full tw:cursor-pointer"
        type="button"
      >
        Collapse Form
      </button>
    </div>
  </form>
  <hr />
  <div
    class="d-flex justify-content-between"
  >
    <h2>
      Items
    </h2>
    <div>
      <div
        class="dropdown"
      >
        <button
          aria-expanded="false"
          class="dropdown-toggle btn btn-light"
          id="filter-by-category-button"
          type="button"
        >
          Filter by category
        </button>
      </div>
    </div>
  </div>
  <div
    class="clearfix"
  >
    <button
      class="mx-auto float-end btn btn-link"
      type="button"
    >
      Select
    </button>
  </div>
  <br />
  <h2>
    Completed Items
  </h2>
  <div
    class="clearfix"
  >
    <button
      class="mx-auto float-end btn btn-link"
      type="button"
    >
