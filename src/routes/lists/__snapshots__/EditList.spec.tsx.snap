exports[`EditList > renders the Loading component when fetch request is pending 1`] = `
<div>
  <div
    id="loader"
  >
    <div
      class="inline-block h-8 w-8 animate-spin rounded-full border-4 border-current border-t-transparent"
      id="spinner"
      role="status"
    >
      <span
        class="sr-only"
      >
        Loading...
      </span>
    </div>
  </div>
</div>
`;
