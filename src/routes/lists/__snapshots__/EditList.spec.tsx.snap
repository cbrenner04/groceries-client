exports[`EditList > renders the Loading component when fetch request is pending 1`] = `
<div>
  <div
    id="loader"
  >
    <div
      class="tw:inline-block tw:h-8 tw:w-8 tw:animate-spin tw:rounded-full tw:border-4 tw:border-current tw:border-t-transparent"
      id="spinner"
      role="status"
    >
      <span
        class="tw:sr-only"
      >
        Loading...
      </span>
    </div>
  </div>
</div>
`;
