exports[`EditList > displays EditList 1`] = `
<div>
  <h1>
    Edit List
  </h1>
  <br />
  <form
    autocomplete="off"
  >
    <div
      class="tw:mb-3"
    >
      <div
        class="tw:w-full"
      >
        <label
          class="tw:block tw:text-sm tw:font-medium tw:text-[var(--color-text-secondary)] tw:mb-2"
          for="name"
        >
          Name
        </label>
        <input
          class="tw:w-full tw:h-11 tw:px-4 tw:py-2 tw:bg-[var(--color-surface)] tw:border tw:border-[var(--color-border)] tw:rounded-lg tw:text-base tw:transition-colors tw:focus:outline-none tw:focus:ring-2 tw:focus:ring-[var(--color-primary)]/30 tw:focus:border-[var(--color-border-strong)]"
          id="name"
          name="name"
          placeholder="My super cool list"
          type="text"
          value="foo"
        />
      </div>
    </div>
    <div
      class="mb-3 tw:mb-3"
    >
      <div
        class="tw:flex tw:items-center tw:min-h-[44px] tw:cursor-pointer tw:gap-3"
      >
        <div
          class="tw:relative tw:w-5 tw:h-5"
        >
          <input
            class="tw:appearance-none tw:absolute tw:w-5 tw:h-5 tw:rounded tw:border-2 tw:border-[var(--color-border)] tw:bg-[var(--color-surface)] tw:cursor-pointer tw:transition-colors tw:focus:outline-none tw:focus:ring-2 tw:focus:ring-[var(--color-primary)]/30"
            id="completed"
            name="completed"
            type="checkbox"
          />
          <div
            class="tw:absolute tw:inset-0 tw:w-5 tw:h-5 tw:rounded tw:border-2 tw:border-[var(--color-border)] tw:bg-[var(--color-surface)] tw:pointer-events-none"
          />
        </div>
        <label
          class="tw:text-sm tw:select-none tw:text-[var(--color-text-primary)] tw:cursor-pointer tw:mb-0"
          for="completed"
        >
          Completed
        </label>
      </div>
    </div>
    <div
      class="d-grid gap-2 mt-3"
    >
      <button
        class="tw:font-medium tw:transition-colors tw:duration-200 tw:ease-in-out tw:min-h-[44px] tw:flex tw:items-center tw:justify-center tw:gap-2 tw:bg-[var(--color-success)] tw:text-white tw:hover:opacity-90 tw:active:opacity-80 tw:h-10 tw:px-4 tw:text-sm tw:rounded-lg tw:w-full tw:cursor-pointer"
        type="submit"
      >
        Update List
      </button>
      <button
        class="tw:font-medium tw:transition-colors tw:duration-200 tw:ease-in-out tw:min-h-[44px] tw:flex tw:items-center tw:justify-center tw:gap-2 tw:text-[var(--color-text-secondary)] tw:hover:bg-[var(--color-surface-overlay)] tw:active:bg-[var(--color-surface-raised)] tw:h-10 tw:px-4 tw:text-sm tw:rounded-lg tw:w-full tw:cursor-pointer"
        type="button"
      >
        Cancel
      </button>
    </div>
  </form>
</div>
`;

exports[`EditList > displays UnknownError when an error occurs 1`] = `
<div>
  <div
    class="tw:flex tw:flex-col tw:min-h-[calc(100vh-var(--spacing-nav-height))]"
  >
    <main
      class="tw:flex-1 tw:overflow-y-auto tw:px-4 tw:py-4"
    >
      <div
        class="tw:flex tw:flex-col tw:items-center tw:justify-center tw:py-16 tw:px-4 tw:text-center"
      >
        <div
          class="tw:text-[var(--color-text-tertiary)] tw:mb-4 tw:[&>svg]:tw:w-16 tw:[&>svg]:tw:h-16"
        >
          <svg
            aria-hidden="true"
            fill="currentColor"
            focusable="false"
            height="48"
            role="img"
            style="display: inline-block; vertical-align: middle;"
            viewBox="0 0 512 512"
            width="48"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              d="M464 256A208 208 0 1 0 48 256a208 208 0 1 0 416 0zM0 256a256 256 0 1 1 512 0A256 256 0 1 1 0 256zm169.8-90.7c7.9-22.3 29.1-37.3 52.8-37.3h58.3c34.9 0 63.1 28.3 63.1 63.1c0 22.6-12.1 43.5-31.7 54.8L280 264.4c-.2 13-10.9 23.6-24 23.6c-13.3 0-24-10.7-24-24V250.5c0-8.6 4.6-16.5 12.1-20.8l44.3-25.4c4.7-2.7 7.6-7.7 7.6-13.1c0-8.4-6.8-15.1-15.1-15.1H222.6c-3.4 0-6.4 2.1-7.5 5.3l-.4 1.2c-4.4 12.5-18.2 19-30.6 14.6s-19-18.2-14.6-30.6l.4-1.2zM224 352a32 32 0 1 1 64 0 32 32 0 1 1 -64 0z"
            />
          </svg>
        </div>
        <h2
          class="tw:text-lg tw:font-medium tw:text-[var(--color-text-primary)] tw:mb-1"
        >
          Something went wrong!
        </h2>
        <p
          class="tw:text-sm tw:text-[var(--color-text-secondary)] tw:mb-4 tw:max-w-xs"
        >
          We are currently unable to render this page.
        </p>
        <button
          class="tw:font-medium tw:transition-colors tw:duration-200 tw:ease-in-out tw:min-h-[44px] tw:flex tw:items-center tw:justify-center tw:gap-2 tw:bg-[var(--color-primary)] tw:text-white tw:hover:bg-[var(--color-primary-hover)] tw:active:opacity-90 tw:h-10 tw:px-4 tw:text-sm tw:rounded-lg  tw:cursor-pointer"
          type="button"
        >
          refresh the page
        </button>
      </div>
    </main>
  </div>
</div>
`;

